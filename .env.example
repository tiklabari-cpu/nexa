# Nexa — local development environment.
# Copy to `.env` (`make env`). NEVER commit `.env`.

NODE_ENV=development
NEXA_REGION=eu

# --- Datastores (ports offset to avoid clashing with any local postgres/redis) ---
# Migrations/DDL run as the owner; the API runtime uses nexa_app so RLS applies.
DATABASE_URL=postgresql://nexa:nexa_dev_password@localhost:5433/nexa
DATABASE_APP_URL=postgresql://nexa_app:nexa_app_dev_password@localhost:5433/nexa
REDIS_URL=redis://localhost:6380

# --- Services ---
API_PORT=4000
RTM_PORT=4001
WEB_PORT=5173
WIDGET_PORT=5174
API_BASE_URL=http://localhost:4000
RTM_BASE_URL=ws://localhost:4001

# --- Secrets (dev only — rotate for any real deployment) ---
JWT_SIGNING_KEY=dev-only-jwt-signing-key-change-me-0123456789abcdef
WEBHOOK_HMAC_SEED=dev-only-webhook-hmac-seed-change-me-0123456789abcdef
CUSTOMER_TOKEN_SECRET=dev-only-customer-token-secret-change-me-0123456789

# --- Token lifetimes (seconds) ---
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=2592000
CUSTOMER_TOKEN_TTL=28800
AUTH_CODE_TTL=120

# --- Rate limits (ADR-07) ---
RATE_LIMIT_AGENT_PER_MIN=180
RATE_LIMIT_AGENT_BURST=30
RATE_LIMIT_CUSTOMER_PER_MIN=60
# Unauthenticated per IP: sign-in, token exchange, widget tokens. The e2e suite
# drives all three in a tight loop — .env raises this locally, and CI does too.
RATE_LIMIT_ANON_PER_MIN=30
RATE_LIMIT_RTM_PER_SEC=10

# --- Billing (ADR-13) — Stripe is mocked, no external calls ---
TRIAL_DAYS=14
UNIT_PRICE_CENTS=9900
AI_RESOLUTIONS_INCLUDED=200
AI_OVERAGE_CENTS=50

# --- Mocked providers ---
LLM_PROVIDER=mock
MAIL_PROVIDER=mock
STORAGE_PROVIDER=local
STRIPE_PROVIDER=mock
