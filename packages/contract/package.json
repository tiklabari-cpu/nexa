{
  "name": "@nexa/contract",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openapi.json": "./dist/openapi.json"
  },
  "scripts": {
    "bundle": "tsx scripts/bundle.ts",
    "generate": "pnpm bundle && openapi-typescript dist/openapi.json -o src/generated/api.ts && prettier --write src/generated/api.ts",
    "build": "pnpm bundle",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src scripts",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@nexa/types": "workspace:*"
  },
  "devDependencies": {
    "@redocly/openapi-core": "^1.28.0",
    "openapi-typescript": "^7.4.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4",
    "yaml": "^2.6.1"
  }
}
