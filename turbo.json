{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".env"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "JWT_SIGNING_KEY",
    "WEBHOOK_HMAC_SEED",
    "API_PORT",
    "RTM_PORT",
    "API_BASE_URL",
    "RTM_BASE_URL",
    "RATE_LIMIT_AGENT_PER_MIN",
    "RATE_LIMIT_AGENT_BURST",
    "RATE_LIMIT_CUSTOMER_PER_MIN",
    "RATE_LIMIT_RTM_PER_SEC",
    "AI_OVERAGE_CENTS",
    "TRIAL_DAYS",
    "NEXA_REGION"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".vite/**"]
    },
    "generate": {
      "outputs": ["src/generated/**"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
